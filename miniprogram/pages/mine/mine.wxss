/* pages/mine/mine.wxss - 我的页面样式 */

.mine-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部区域 */
.header-section {
  padding: 0 24rpx;
}

.header-bg {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 40rpx 0 60rpx;
}

.user-card {
  position: relative;
  display: flex;
  align-items: center;
}

/* 未登录 */
.user-unlogin {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.login-info {
  display: flex;
  flex-direction: column;
}

.login-btn {
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 已登录 */
.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 刷新按钮 */
.refresh-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-btn image {
  width: 32rpx;
  height: 32rpx;
}

/* 数据统计 */
.stats-section {
  padding: 0 24rpx;
  margin-top: -30rpx;
}

.stats-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eeeeee;
}

/* 广告提示 */
.ad-tip-section {
  padding: 20rpx 24rpx 0;
}

.ad-tip-card {
  background: #fff9e6;
  border: 1rpx solid #f0a020;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.tip-left image {
  width: 32rpx;
  height: 32rpx;
}

.tip-left .highlight {
  color: #f0a020;
  font-weight: 600;
}

.tip-right {
  font-size: 24rpx;
  color: #f0a020;
}

/* 功能菜单 */
.menu-section {
  padding: 20rpx 24rpx 0;
}

.menu-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon image {
  width: 32rpx;
  height: 32rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
}

/* 最近下载 */
.history-section {
  padding: 20rpx 24rpx 0;
}

.history-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.more-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #999999;
}

.more-btn image {
  width: 24rpx;
  height: 24rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.item-cover {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.item-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 底部分享 */
.footer-section {
  padding: 32rpx 24rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 28rpx;
  background: #ffffff;
  border: 2rpx solid #07c160;
  border-radius: 44rpx;
}

.share-btn image {
  width: 36rpx;
  height: 36rpx;
}

.share-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #07c160;
}

.share-btn::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 20rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #cccccc;
}
