/* pages/about/about.wxss */

/* 应用头部 */
.app-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
}

.app-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 8rpx 30rpx rgba(7, 193, 96, 0.3);
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 24rpx;
}

.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 区块 */
.section {
  padding: 40rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

/* 简介卡片 */
.intro-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.intro-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 功能特点 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.feature-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feature-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #e8f8ed;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.feature-icon {
  width: 48rpx;
  height: 48rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
}

/* 联系方式 */
.contact-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: #333;
}

.contact-value-wrap {
  display: flex;
  align-items: center;
}

.contact-value {
  font-size: 26rpx;
  color: #666;
}

.contact-action {
  font-size: 24rpx;
  color: #07c160;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  background: #e8f8ed;
  border-radius: 8rpx;
}

/* 协议链接 */
.link-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.link-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.link-item:last-child {
  border-bottom: none;
}

.link-text {
  font-size: 28rpx;
  color: #333;
}

.link-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 底部版权 */
.footer {
  padding: 60rpx 0 40rpx;
  text-align: center;
}

.copyright {
  font-size: 24rpx;
  color: #ccc;
}
