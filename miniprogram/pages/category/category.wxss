/* pages/category/category.wxss - 分类页样式 */

.category-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background: #ffffff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 分类标签 */
.category-scroll {
  background: #ffffff;
  white-space: nowrap;
  padding-bottom: 20rpx;
}

.category-tabs {
  display: inline-flex;
  padding: 0 16rpx;
}

.category-tab {
  padding: 12rpx 28rpx;
  margin: 0 8rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  background: #f5f5f5;
  white-space: nowrap;
}

.category-tab.active {
  background: #07c160;
  color: #ffffff;
  font-weight: 600;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #ffffff;
  margin-top: 2rpx;
}

.total-count {
  font-size: 26rpx;
  color: #999999;
}

.sort-right {
  display: flex;
  gap: 24rpx;
}

.sort-item {
  font-size: 26rpx;
  color: #999999;
}

.sort-item.active {
  color: #07c160;
  font-weight: 600;
}

/* 资源列表 */
.resource-list {
  padding: 20rpx 24rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.resource-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.resource-cover image {
  width: 100%;
  height: 100%;
}

.resource-info {
  flex: 1;
}

.resource-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.resource-category {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.resource-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #999999;
}

.meta-item image {
  width: 24rpx;
  height: 24rpx;
}

.resource-size {
  font-size: 24rpx;
  color: #999999;
}

.download-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.download-btn image {
  width: 48rpx;
  height: 48rpx;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  color: #999999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
}
