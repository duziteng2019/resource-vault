/* pages/resource-detail/resource-detail.wxss - 资源详情页样式 */

.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 顶部封面 */
.detail-header {
  position: relative;
  height: 400rpx;
}

.header-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
}

.back-btn,
.share-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn image,
.share-btn image {
  width: 36rpx;
  height: 36rpx;
}

/* 信息卡片 */
.info-card {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -40rpx;
  padding: 32rpx;
  position: relative;
  z-index: 1;
}

.resource-title {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.tag-row {
  display: flex;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.category-tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.version-tag {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

/* 数据统计 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 详情区块 */
.detail-section,
.intro-section {
  background: #ffffff;
  margin-top: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.detail-content-box {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666666;
}

.detail-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 简介 */
.intro-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.item-tag {
  padding: 8rpx 20rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.count-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.count-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-icon image {
  width: 32rpx;
  height: 32rpx;
}

.count-info {
  display: flex;
  flex-direction: column;
}

.count-label {
  font-size: 22rpx;
  color: #999999;
}

.count-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #07c160;
}

.action-btns {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn .btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.watch-ad {
  background: #ffffff;
  border: 2rpx solid #07c160;
  color: #07c160;
  flex-direction: column;
  padding: 16rpx;
}

.watch-ad text {
  display: block;
}

.watch-ad .btn-tip {
  font-size: 20rpx;
  font-weight: 400;
  opacity: 0.7;
}

.download-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
}

/* 余额不足弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.balance-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  text-align: center;
  padding-bottom: 32rpx;
}

.modal-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.modal-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.highlight {
  color: #07c160;
  font-weight: 600;
}

.modal-body {
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.body-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.option-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-icon.ad {
  background: #07c160;
}

.option-icon.signin {
  background: #f0a020;
}

.option-icon image {
  width: 36rpx;
  height: 36rpx;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.option-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.option-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.modal-footer {
  padding-top: 8rpx;
}

.modal-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.modal-btn::after {
  border: none;
}
